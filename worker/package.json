{
  "name": "komikone-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create komikone",
    "db:migrate:local": "wrangler d1 execute komikone --local --file=./schema.sql",
    "db:migrate:prod": "wrangler d1 execute komikone --remote --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "typescript": "^6.0.3",
    "wrangler": "^3.91.0"
  },
  "dependencies": {
    "hono": "^4.6.14"
  }
}
